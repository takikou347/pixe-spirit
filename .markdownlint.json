{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json",
  "default": true,

  "// 見出し": "-------------------------------------------",
  "MD001": true,
  "MD003": { "style": "atx" },
  "MD018": true,
  "MD019": true,
  "MD022": true,
  "MD023": true,
  "MD024": { "siblings_only": true },
  "MD025": true,
  "MD041": false,

  "// リスト": "-------------------------------------------",
  "MD004": { "style": "dash" },
  "MD005": true,
  "MD007": { "indent": 2 },
  "MD029": { "style": "ordered" },
  "MD030": true,
  "MD032": true,

  "// 空白・改行": "--------------------------------------",
  "MD009": true,
  "MD010": true,
  "MD012": true,
  "MD013": false,
  "MD047": true,

  "// コードブロック": "----------------------------------",
  "MD014": true,
  "MD031": true,
  "MD040": true,
  "MD046": { "style": "fenced" },
  "MD048": { "style": "backtick" },

  "// インライン書式": "--------------------------------",
  "MD036": true,
  "MD037": true,
  "MD038": true,
  "MD049": { "style": "asterisk" },
  "MD050": { "style": "asterisk" },

  "// リンク・画像": "----------------------------------",
  "MD011": true,
  "MD034": true,
  "MD039": true,
  "MD042": true,
  "MD045": true,
  "MD051": true,
  "MD052": true,
  "MD053": true,

  "// テーブル": "--------------------------------------",
  "MD055": { "style": "leading_and_trailing" },
  "MD056": true,
  "MD058": true,

  "// 引用": "------------------------------------------",
  "MD027": true,
  "MD028": true,

  "// その他": "----------------------------------------",
  "MD026": { "punctuation": ".,;:!。．；：！" },
  "MD033": { "allowed_elements": ["br", "sub", "sup", "details", "summary", "kbd"] },
  "MD035": { "style": "---" },
  "MD060": false
}
