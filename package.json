{
  "name": "pixe-spirit",
  "version": "0.1.0",
  "description": "Seed-deterministic pixel spirit generator. Outputs pure pixel data — rendering is up to you.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "build:docs": "tsup && cp dist/index.js docs/lib/index.js && cp dist/index.js.map docs/lib/index.js.map",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "pixel-art",
    "sprite",
    "character-generator",
    "deterministic",
    "seed",
    "spirit",
    "pixel"
  ],
  "author": "takikou347",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/takikou347/pixe-spirit.git"
  },
  "homepage": "https://github.com/takikou347/pixe-spirit",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
